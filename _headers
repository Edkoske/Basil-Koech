/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self' https://formsubmit.co; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://formsubmit.co; worker-src 'none'; manifest-src 'self'

/tailwind.css
  Cache-Control: public, max-age=86400

/content.js
  Cache-Control: public, max-age=3600

/script.js
  Cache-Control: public, max-age=3600

/security.js
  Cache-Control: public, max-age=3600

/styles.css
  Cache-Control: public, max-age=86400
